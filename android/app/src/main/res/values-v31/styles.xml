<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ 는 시스템 SplashScreen API 를 사용합니다:
     브랜드 배경 + 가운데 로고 아이콘. 이후 앱 테마로 전환. -->
<resources>
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowSplashScreenBackground">@color/brandSplash</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
